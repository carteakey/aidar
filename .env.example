# Copy to .env and fill values.
# .env is gitignored.

# SQLite DB path used by scripts/litestream.
AIDAR_DB=aidar.db

# Litestream / S3-compatible replica target (Cloudflare R2, S3, etc.)
LITESTREAM_BUCKET=your-bucket-name
LITESTREAM_ENDPOINT=https://<account>.r2.cloudflarestorage.com
LITESTREAM_ACCESS_KEY_ID=replace-me
LITESTREAM_SECRET_ACCESS_KEY=replace-me

# Optional local defaults for automation scripts
HEROKU_APP=aidar
HN_DOMAINS=25
HN_STORY_LIMIT=250
HN_MIN_STORY_COUNT=2
DOMAIN_PAGE_LIMIT=200
CONCURRENCY=10
MAX_CYCLES=1
